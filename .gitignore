# OS
.DS_Store
Thumbs.db
desktop.ini

# Editors
.vscode/
.idea/
*.swp
*~

# Dependencies and build output
node_modules/
dist/
# ...except the editorial site's committed precompiled JS at the repo root
# (a source-derived artifact like img/responsive, generated by
# scripts/gen-compiled.mjs), which the build-free static deploy serves directly.
!/dist/
!/dist/**

# Misc
*.log

# Local CDN mirror used by smoke tests (npm copies of unpkg.com assets)
_local_cdn/

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
.env*
!.env.example

# Photo candidates awaiting selection (fetch-guide-photos.mjs); selected
# photos land in apps/guide/public/photos/, candidates never ship.
scripts/data/photo-candidates/

# Cached USGS quad + terrain-tile downloads for scripts/gen-hike-tracks.mjs;
# regenerated on demand, never committed.
scripts/data/.trailcache/
