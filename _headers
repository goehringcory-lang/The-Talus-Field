# Cloudflare Pages response headers.

# Default for all routes.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: interest-cohort=()

# robots.txt and sitemap should never be cached aggressively so
# updates to AI/search permissions propagate quickly.
/robots.txt
  Cache-Control: public, max-age=300, must-revalidate
  Content-Type: text/plain; charset=utf-8

/sitemap.xml
  Cache-Control: public, max-age=300, must-revalidate
  Content-Type: application/xml; charset=utf-8

/llms.txt
  Cache-Control: public, max-age=300, must-revalidate
  Content-Type: text/plain; charset=utf-8

# Static assets — cache aggressively, the ?v=N cache-buster handles changes.
/img/*
  Cache-Control: public, max-age=2592000, immutable

/styles.css
  Cache-Control: public, max-age=86400

# JSX bodies and pages are loaded with explicit version query strings.
/*.jsx
  Cache-Control: public, max-age=86400
