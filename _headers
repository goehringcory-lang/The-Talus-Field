# Cloudflare Pages response headers.

# Default for all routes. The /* fall-through is also where HTML pages
# (rendered from index.html via the SPA history router) get their headers
# — keep them on no-cache so users always pick up the latest cache-buster
# query strings on /styles.css?v=N and /*.jsx?v=N.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: interest-cohort=()
  Cache-Control: public, max-age=0, must-revalidate
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://unpkg.com https://maps.googleapis.com https://maps.gstatic.com https://api.thetalusfieldjournal.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://api.thetalusfieldjournal.com https://www.google-analytics.com https://region1.google-analytics.com https://maps.googleapis.com https://maps.gstatic.com https://npsvms-338365424831-us-west-1-an.s3.us-west-1.amazonaws.com; worker-src 'self' blob:; frame-src 'self' https://buttondown.com https://www.youtube-nocookie.com; frame-ancestors 'none'; form-action 'self' https://buttondown.com

# robots.txt and sitemap should never be cached aggressively so
# updates to AI/search permissions propagate quickly.
/robots.txt
  Cache-Control: public, max-age=300, must-revalidate
  Content-Type: text/plain; charset=utf-8

/sitemap.xml
  Cache-Control: public, max-age=300, must-revalidate
  Content-Type: application/xml; charset=utf-8

/feed.xml
  Cache-Control: public, max-age=300, must-revalidate
  Content-Type: application/rss+xml; charset=utf-8

/llms.txt
  Cache-Control: public, max-age=300, must-revalidate
  Content-Type: text/plain; charset=utf-8

# Static assets — cache aggressively, the ?v=N cache-buster handles changes.
/img/*
  Cache-Control: public, max-age=2592000, immutable

# Self-hosted React UMD builds. Version-stamped filenames, safe to cache hard.
/vendor/*
  Cache-Control: public, max-age=31536000, immutable

# Favicon. Keep TTL moderate so an icon refresh propagates within a day
# rather than the /img/* month-long TTL.
/favicon.ico
  Cache-Control: public, max-age=86400, must-revalidate
  Content-Type: image/x-icon

/styles.css
  Cache-Control: public, max-age=300, stale-while-revalidate=600

# JSX bodies and pages are loaded with explicit version query strings.
# Short TTL + stale-while-revalidate means a forgotten ?v=N bump heals
# in minutes rather than the previous 24-hour cache window.
/*.jsx
  Cache-Control: public, max-age=300, stale-while-revalidate=600

# Precompiled page scripts under /dist load with the same explicit ?v=N
# query strings as the jsx sources; same rationale as /*.jsx above. Without
# this rule they fall through to /* and revalidate on every page load.
/dist/*
  Cache-Control: public, max-age=300, stale-while-revalidate=600

# Prerendered article prose fragments are fetched by functions/_middleware.js
# and injected into each article's HTML. The raw fragment URLs are duplicate
# content and must never be indexed on their own.
/prerender/*
  X-Robots-Tag: noindex

# IndexNow ownership key file. Served as plain text per the IndexNow
# protocol so Bing/Yandex/Seznam can verify and accept URL submissions.
/a1c4a884dc3d1469bbe8aaa26caa7a87.txt
  Cache-Control: public, max-age=86400
  Content-Type: text/plain; charset=utf-8
