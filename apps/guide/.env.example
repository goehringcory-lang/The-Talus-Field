# Local dev: point at the Worker running via `wrangler dev`.
# Production: https://api.thetalusfieldjournal.com (set in Cloudflare Pages env).
VITE_API_BASE=http://localhost:8787

# Google Maps JS API key for the /map route. Token-substituted into
# index.html at build time. The key must be HTTP-referrer-restricted to
# include this app's origin (e.g. http://localhost:5173/*, *.pages.dev/*,
# https://guide.thetalusfieldjournal.com/*) in the Google Cloud console.
# Maps JavaScript API must be enabled on the project.
VITE_GOOGLE_MAPS_API_KEY=
