# The app is auth-gated and should never appear in search results,
# on the unlisted pages.dev host or the production domain.
/*
  X-Robots-Tag: noindex

# The shell must revalidate on every load so a deploy reaches clients on
# their next visit; hashed /assets/* carry the real long-lived caching.
/
  Cache-Control: public, max-age=0, must-revalidate

/index.html
  Cache-Control: public, max-age=0, must-revalidate

/sw.js
  Cache-Control: public, max-age=0, must-revalidate

/manifest.webmanifest
  Cache-Control: public, max-age=0, must-revalidate

/assets/*
  Cache-Control: public, max-age=31536000, immutable
